# مطلوب — بدونه المحادثة تشتغل بأزرار فقط
# مع المفتاح: Claude يستخرج المعلومات من نص حر (Gulf Arabic NLU)،
# يحلّل سياسات الخصوصية، ويولّد المستندات، ويفحص توفّر اسم الشركة.
ANTHROPIC_API_KEY=sk-ant-...

# اختياري لكن موصى به للديمو — مفتاح احتياطي يُستعمل تلقائياً
# لو الأساسي ضرب rate limit (30k tokens/min على الـ tier المجاني).
# lib/claude.ts يرصد أخطاء 429 ويحوّل للمفتاح الاحتياطي بدون تدخّل.
ANTHROPIC_API_KEY_BACKUP=sk-ant-...

# اختياري — للـ deployment
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
