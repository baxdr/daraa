# ─────────────────────────────────────────────────────────────────────────
# درع — Environment variables
# Copy this file to `.env.local` for development.
# In production, set these in your hosting provider's dashboard
# (Vercel → Project → Settings → Environment Variables).
# ─────────────────────────────────────────────────────────────────────────

# ── Anthropic (strongly recommended) ────────────────────────────────────
# Enables Claude-powered path: privacy-policy deep analysis, document
# generation, research-agent web search. Without it the product still works
# via deterministic fallbacks, but the experience is degraded.
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (reserved — Week 2 persistence) ────────────────────────────
# The MVP uses in-process stores on globalThis. These vars are documented
# here so nothing breaks when the persistence layer lands. Leave empty
# during the hackathon.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Headless browser (reserved — cookie-consent detection) ──────────────
# When cookie-consent scanning is enabled, point this at a Browserless.io
# endpoint (or any compatible chrome-ws URL).
BROWSERLESS_URL=
