# Supabase Configuration (Phase 3+)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Persistence Driver: 'filesystem' (default) or 'supabase' (Phase 3+)
PERSISTENCE_DRIVER=filesystem

# System workspace ID for anonymous projects
NEXT_PUBLIC_SYSTEM_WORKSPACE_ID=system

# Anthropic API — Required for chat and document generation
ANTHROPIC_API_KEY=sk-ant-...

# Backup Anthropic key (optional but recommended for production)
ANTHROPIC_API_KEY_BACKUP=sk-ant-...

# Deployment URL (optional)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Feature flags
NEXT_PUBLIC_ENABLE_AGENT_TELEMETRY=true
